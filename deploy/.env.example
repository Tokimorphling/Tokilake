# --- Tokilake Hub Configuration ---

# Your public domain (e.g., api.example.com)
DOMAIN=api.example.com

# Timezone (e.g., Asia/Shanghai)
TZ=UTC

# Secrets - Please change these to long random strings (min 32 chars)
SESSION_SECRET=replace-with-a-random-session-secret
USER_TOKEN_SECRET=replace-with-at-least-32-random-characters

